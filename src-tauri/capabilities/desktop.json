{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "updater:default",
    "sql:default",
    "sql:allow-execute",
    "core:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": ["$LOCALDATA/*"]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "args": false,
          "cmd": "",
          "name": "bin/stockfish",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "shell:allow-stdin-write",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://lichess.org/*" }]
    },
    "deep-link:default",
    "dialog:allow-confirm"
  ]
}
