{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "trailingComma": "es5",
  "sortPackageJson": false,
  "sortImports": { "newlinesBetween": false },
  "jsdoc": { "commentLineStrategy": "multiline", "preferCodeFences": true, "descriptionWithDot": true },
  "ignorePatterns": ["dist"]
}
